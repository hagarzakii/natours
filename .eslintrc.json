{
  "extends": ["airbnb", "prettier", "plugin:node/recommended"],
  "plugins": ["prettier"],
  "rules": {
    "import/newline-after-import": "off",
    "prettier/prettier": [
      "error",
      {
        "singleQuote": true,
        "endOfLine": "auto" // <-- prevents "Delete ␍" on Windows
      }
    ],
    "node/no-unsupported-features/es-syntax": "off",
    "quotes": ["off", "single", { "avoidEscape": true }],
    "spaced-comment": "off",
    "no-console": "off",
    "consistent-return": "off",
    "func-names": "off",
    "object-shorthand": "off",
    "no-process-exit": "off",
    "no-param-reassign": "off",
    "no-return-await": "off",
    "no-underscore-dangle": "off",
    "class-methods-use-this": "off",
    "prefer-destructuring": ["off", { "object": true, "array": false }],
    "no-unused-vars": ["off", { "argsIgnorePattern": "req|res|next|val" }],
    "linebreak-style": "off" // <-- ignore LF/CRLF differences
  }
}
